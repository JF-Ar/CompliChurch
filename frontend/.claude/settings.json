{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": ["../contracts"],
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(next *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(docker logs *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose ps *)",
      "Bash(docker ps *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(rm *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git reset --hard *)",
      "Bash(go *)",
      "Bash(sqlc *)",
      "Bash(migrate *)",
      "Write(../backend/**)",
      "Edit(../backend/**)",
      "Write(../contracts/**)",
      "Edit(../contracts/**)"
    ]
  }
}